# Variaveis de ambiente do G Obra
# Copie esse arquivo pra .env.local e preencha com as chaves reais.
# No Vercel, configure essas mesmas chaves em Settings -> Environment Variables.

# Supabase — pegar em supabase.com -> seu projeto -> Project Settings -> API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...sua_anon_key_aqui

# Z-API (WhatsApp) — adicionar quando for habilitar notificacoes
# VITE_ZAPI_INSTANCE=
# VITE_ZAPI_TOKEN=
